<GuiXml>
    <Controls>

        <TopLevelControl name="GPH_MapSearch_Gamepad" hidden="true">
            <Controls>

                <!-- Left panel: search box + results list -->
                <Control name="$(parent)Main" inherits="ZO_WorldMapInfoContent_Gamepad">
                    <Controls>

                        <!-- Gamepad-style search bar: icon + edit + highlight on focus -->
                        <Control name="$(parent)SearchBar">
                            <Anchor point="TOPLEFT"  offsetX="0" offsetY="20"/>
                            <Anchor point="TOPRIGHT" offsetX="0" offsetY="20"/>
                            <Dimensions y="56"/>
                            <Controls>

                                <!-- Always-visible grey outline -->
                                <Backdrop name="$(parent)Border" inherits="ZO_GamepadGreyOutlineThin">
                                    <AnchorFill/>
                                </Backdrop>

                                <!-- Semi-transparent fill, visible only when focused -->
                                <Texture name="$(parent)BG" color="444444" alpha="0.5" hidden="true">
                                    <AnchorFill/>
                                </Texture>

                                <!-- White-outline highlight, visible only when focused -->
                                <Backdrop name="$(parent)Highlight"
                                          inherits="ZO_GamepadWhiteOutlineHighlight"
                                          tier="HIGH" layer="OVERLAY" blendMode="ADD" hidden="true">
                                    <AnchorFill/>
                                </Backdrop>

                                <!-- Magnifying-glass icon; dimmed when idle, bright when focused -->
                                <Texture name="$(parent)Icon"
                                         textureFile="EsoUI/Art/Miscellaneous/Gamepad/gp_icon_search_64.dds"
                                         color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_DISABLED">
                                    <Dimensions x="48" y="48"/>
                                    <Anchor point="LEFT" offsetX="6"/>
                                </Texture>

                                <EditBox name="$(parent)Edit"
                                         maxInputCharacters="50"
                                         inherits="ZO_DefaultEditForBackdrop_Gamepad ZO_EditDefaultText">
                                    <Anchor point="LEFT"
                                            relativeTo="$(parent)Icon"
                                            relativePoint="RIGHT"
                                            offsetX="8"/>
                                    <Anchor point="RIGHT" offsetX="-8"/>
                                    <OnEffectivelyShown>
                                        GPH_MapSearch_OnShown(self)
                                    </OnEffectivelyShown>
                                    <OnTextChanged>
                                        GPH_MapSearch_OnTextChanged(self:GetText())
                                    </OnTextChanged>
                                    <OnFocusGained>
                                        GPH_MapSearch_OnSearchFocused(true)
                                    </OnFocusGained>
                                    <OnFocusLost>
                                        GPH_MapSearch_OnSearchFocused(false)
                                    </OnFocusLost>
                                    <OnEnter>
                                        GPH_MapSearch_SelectCurrent()
                                    </OnEnter>
                                    <OnTab>
                                        GPH_MapSearch_FocusList()
                                    </OnTab>
                                    <OnDownArrow>
                                        GPH_MapSearch_FocusList()
                                    </OnDownArrow>
                                    <OnEscape>
                                        self:LoseFocus()
                                    </OnEscape>
                                </EditBox>

                            </Controls>
                        </Control>

                        <Control name="$(parent)List" inherits="ZO_VerticalParametricScrollListTemplate">
                            <Anchor point="TOPLEFT"
                                    relativeTo="$(parent)SearchBar"
                                    relativePoint="BOTTOMLEFT"
                                    offsetY="4"/>
                            <Anchor point="BOTTOMRIGHT"/>
                        </Control>

                    </Controls>
                </Control>

                <!-- Right info panel — standard gamepad quadrant 4 -->
                <Control name="$(parent)SideContent" inherits="ZO_GamepadGrid_NavQuadrant_4_Anchors">
                    <Controls>
                        <Control name="$(parent)Container" inherits="ZO_GamepadGrid_NavQuadrant_ContainerAnchors">
                            <Controls>

                                <Label name="$(parent)TypeLabel"
                                       font="ZoFontGamepadBold22"
                                       color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_SELECTED"
                                       modifyTextType="UPPERCASE"
                                       wrapMode="ELLIPSIS"
                                       horizontalAlignment="LEFT">
                                    <Anchor point="TOPLEFT"  offsetY="ZO_GAMEPAD_CONTENT_HEADER_DIVIDER_OFFSET_Y"/>
                                    <Anchor point="TOPRIGHT" offsetY="ZO_GAMEPAD_CONTENT_HEADER_DIVIDER_OFFSET_Y"/>
                                </Label>

                                <!-- Location icon: left of the zone name -->
                                <Texture name="$(parent)LocationIcon"
                                         hidden="true">
                                    <Dimensions x="48" y="48"/>
                                    <Anchor point="TOPLEFT"
                                            relativeTo="$(parent)TypeLabel"
                                            relativePoint="BOTTOMLEFT"
                                            offsetY="6"/>
                                </Texture>

                                <Label name="$(parent)ZoneName"
                                       font="ZoFontGamepadCondensed42"
                                       color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_NORMAL"
                                       wrapMode="WRAP"
                                       horizontalAlignment="LEFT"
                                       verticalAlignment="TOP">
                                    <Anchor point="TOPLEFT"
                                            relativeTo="$(parent)LocationIcon"
                                            relativePoint="TOPRIGHT"
                                            offsetX="8"/>
                                    <Anchor point="TOPRIGHT"
                                            relativeTo="$(parent)TypeLabel"
                                            relativePoint="BOTTOMRIGHT"
                                            offsetY="6"/>
                                </Label>

                                <!-- Sub-description: vendor type, dungeon info, etc. -->
                                <Label name="$(parent)DescriptionLabel"
                                       font="ZoFontGamepadBold22"
                                       color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_SELECTED"
                                       wrapMode="WRAP"
                                       horizontalAlignment="LEFT"
                                       hidden="true">
                                    <Anchor point="TOPLEFT"
                                            relativeTo="$(parent)ZoneName"
                                            relativePoint="BOTTOMLEFT"
                                            offsetY="6"/>
                                    <Anchor point="TOPRIGHT"
                                            relativeTo="$(parent)ZoneName"
                                            relativePoint="BOTTOMRIGHT"/>
                                </Label>


                            </Controls>
                        </Control>
                    </Controls>
                </Control>

            </Controls>
        </TopLevelControl>

    </Controls>
</GuiXml>
