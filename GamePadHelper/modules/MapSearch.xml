<GuiXml>
    <Controls>
        <TopLevelControl name="GPH_MapSearch_Gamepad" hidden="true">
            <Controls>
                <Control name="$(parent)Main" inherits="ZO_WorldMapInfoContent_Gamepad">
                    <Controls>
                        <Control name="$(parent)RecallRow">
                            <Anchor point="TOPLEFT" offsetX="0" offsetY="22"/>
                            <Anchor point="TOPRIGHT" offsetX="0" offsetY="22"/>
                            <Dimensions y="28"/>
                            <Controls>
                                <Label name="$(parent)RecallCostTitle" font="ZoFontGamepad42" color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_NORMAL">
                                    <Anchor point="LEFT" offsetX="8"/>
                                </Label>
                                <Label name="$(parent)RecallCostValue" font="ZoFontGamepad42" color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_NORMAL">
                                    <Anchor point="RIGHT" offsetX="-8"/>
                                </Label>
                            </Controls>
                        </Control>
                        <Control name="$(parent)Tabs">
                            <Anchor point="TOPLEFT" relativeTo="$(parent)RecallRow" relativePoint="BOTTOMLEFT" offsetX="0" offsetY="20"/>
                            <Anchor point="TOPRIGHT" relativeTo="$(parent)RecallRow" relativePoint="BOTTOMRIGHT" offsetX="0" offsetY="20"/>
                            <Dimensions y="46"/>
                            <Controls>
                                <Label name="$(parent)Previous" font="ZoFontGamepad34" color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_NORMAL" horizontalAlignment="LEFT" wrapMode="ELLIPSIS">
                                    <Anchor point="LEFT" offsetX="8"/>
                                    <Dimensions x="210" y="46"/>
                                </Label>
                                <Label name="$(parent)Next" font="ZoFontGamepad34" color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_NORMAL" horizontalAlignment="RIGHT" wrapMode="ELLIPSIS">
                                    <Anchor point="RIGHT" offsetX="-8"/>
                                    <Dimensions x="210" y="46"/>
                                </Label>
                                <Label name="$(parent)Selected" font="ZoFontGamepad34" color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_NORMAL" horizontalAlignment="CENTER" wrapMode="ELLIPSIS">
                                    <Anchor point="LEFT" relativeTo="$(parent)Previous" relativePoint="RIGHT" offsetX="8"/>
                                    <Anchor point="RIGHT" relativeTo="$(parent)Next" relativePoint="LEFT" offsetX="-8"/>
                                    <Dimensions y="46"/>
                                </Label>
                            </Controls>
                        </Control>
                        <Label name="$(parent)TabTitle" font="ZoFontGamepad42" color="EAA643" horizontalAlignment="CENTER" wrapMode="ELLIPSIS">
                            <Anchor point="TOPLEFT" relativeTo="$(parent)Tabs" relativePoint="BOTTOMLEFT" offsetX="0" offsetY="20"/>
                            <Anchor point="TOPRIGHT" relativeTo="$(parent)Tabs" relativePoint="BOTTOMRIGHT" offsetX="0" offsetY="20"/>
                            <Dimensions y="42"/>
                        </Label>
                        <Control name="$(parent)SearchBar">
                            <Anchor point="TOPLEFT" relativeTo="$(parent)TabTitle" relativePoint="BOTTOMLEFT" offsetX="0" offsetY="18"/>
                            <Anchor point="TOPRIGHT" relativeTo="$(parent)TabTitle" relativePoint="BOTTOMRIGHT" offsetX="0" offsetY="18"/>
                            <Dimensions y="56"/>
                            <Controls>
                                <Backdrop name="$(parent)Border" inherits="ZO_GamepadGreyOutlineThin">
                                    <AnchorFill/>
                                </Backdrop>
                                <Texture name="$(parent)BG" color="444444" alpha="0.5" hidden="true">
                                    <AnchorFill/>
                                </Texture>
                                <Backdrop name="$(parent)Highlight" inherits="ZO_GamepadWhiteOutlineHighlight" tier="HIGH" layer="OVERLAY" blendMode="ADD" hidden="true">
                                    <AnchorFill/>
                                </Backdrop>
                                <Texture name="$(parent)Icon" textureFile="EsoUI/Art/Miscellaneous/Gamepad/gp_icon_search_64.dds" color="INTERFACE_COLOR_TYPE_TEXT_COLORS:INTERFACE_TEXT_COLOR_DISABLED">
                                    <Dimensions x="48" y="48"/>
                                    <Anchor point="LEFT" offsetX="6"/>
                                </Texture>
                                <EditBox name="$(parent)Edit" maxInputCharacters="50" inherits="ZO_DefaultEditForBackdrop_Gamepad">
                                    <Anchor point="LEFT" relativeTo="$(parent)Icon" relativePoint="RIGHT" offsetX="8"/>
                                    <Anchor point="RIGHT" offsetX="-8"/>
                                    <OnEffectivelyShown>
                                        GPH_MapSearch_OnShown(self)
                                    </OnEffectivelyShown>
                                    <OnTextChanged>
                                        GPH_MapSearch_OnTextChanged(self:GetText())
                                    </OnTextChanged>
                                    <OnFocusGained>
                                        GPH_MapSearch_OnSearchFocused(true)
                                    </OnFocusGained>
                                    <OnFocusLost>
                                        GPH_MapSearch_OnSearchFocused(false)
                                    </OnFocusLost>
                                    <OnEnter>
                                        GPH_MapSearch_SelectCurrent()
                                    </OnEnter>
                                    <OnEscape>
                                        self:LoseFocus()
                                    </OnEscape>
                                </EditBox>
                            </Controls>
                        </Control>
                        <Control name="$(parent)List" inherits="ZO_VerticalParametricScrollListTemplate">
                            <Anchor point="TOPLEFT" relativeTo="$(parent)SearchBar" relativePoint="BOTTOMLEFT" offsetY="4"/>
                            <Anchor point="BOTTOMRIGHT"/>
                        </Control>
                    </Controls>
                </Control>
            </Controls>
        </TopLevelControl>
    </Controls>
</GuiXml>
